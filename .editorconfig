# EditorConfig: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python
[*.py]
indent_size = 4

# Go — gofmt uses tabs, don't fight it
[*.go]
indent_style = tab
indent_size = 4

# Rust — rustfmt default
[*.rs]
indent_size = 4

# C / C++ / C#
[*.{c,h,cpp,hpp,cs}]
indent_size = 4

# Java
[*.java]
indent_size = 4

# Makefiles require tabs, always
[Makefile]
indent_style = tab

# Markdown — trailing spaces are meaningful (line breaks), don't trim
[*.md]
trim_trailing_whitespace = false
